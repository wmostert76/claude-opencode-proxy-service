#!/usr/bin/env bash
set -Eeuo pipefail

# Start Claude Code through the local Anthropic -> OpenAI proxy for OpenCode Go.
# Any arguments passed to this script are forwarded to Claude Code.

readonly SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
readonly PROXY_SCRIPT="${PROXY_SCRIPT:-$SCRIPT_DIR/../proxy/anthropic2openai-proxy.mjs}"
readonly REAL_CLAUDE="${REAL_CLAUDE:-$HOME/.local/share/npm-global/lib/node_modules/@anthropic-ai/claude-code/bin/claude.exe}"
readonly CLAUDE_SETTINGS="${CLAUDE_SETTINGS:-$HOME/.claude/settings.json}"
readonly CONFIG_FILE="${CLAUDE_OPENCODE_CONFIG:-$HOME/.config/claude-opencode-proxy/config.json}"
readonly VERSION_FILE="${VERSION_FILE:-$SCRIPT_DIR/../VERSION}"
readonly LOG_FILE="${CLAUDE_OPENCODE_LOG:-$HOME/.cache/claude-opencode-proxy/proxy.log}"
CONFIG_PROXY_HOST="$(CONFIG_PATH="$CONFIG_FILE" python3 <<'PY' 2>/dev/null || true
import json
import os

try:
    with open(os.environ["CONFIG_PATH"], "r", encoding="utf-8") as f:
        cfg = json.load(f)
    print(cfg.get("proxy", {}).get("host", ""))
except Exception:
    pass
PY
)"
CONFIG_PROXY_PORT="$(CONFIG_PATH="$CONFIG_FILE" python3 <<'PY' 2>/dev/null || true
import json
import os

try:
    with open(os.environ["CONFIG_PATH"], "r", encoding="utf-8") as f:
        cfg = json.load(f)
    print(cfg.get("proxy", {}).get("port", ""))
except Exception:
    pass
PY
)"
readonly PROXY_HOST="${PROXY_HOST:-${CONFIG_PROXY_HOST:-127.0.0.1}}"
readonly PROXY_PORT="${PROXY_PORT:-${CONFIG_PROXY_PORT:-8082}}"
readonly PROXY_URL="http://$PROXY_HOST:$PROXY_PORT"
DEFAULT_MODEL="${DEFAULT_MODEL:-}"

PROXY_PID=""
API_KEY=""
STATUS_STARTED_PROXY=0

version() {
  if [[ -r "$VERSION_FILE" ]]; then
    tr -d '[:space:]' < "$VERSION_FILE"
  else
    printf 'dev'
  fi
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1"
}

color() {
  [[ "${NO_COLOR:-}" ]] && return 0
  printf '\033[%sm' "$1"
}

ok() {
  printf '%s%s%s %s\n' "$(color 32)" "OK" "$(color 0)" "$*"
}

warn() {
  printf '%s%s%s %s\n' "$(color 33)" "WARN" "$(color 0)" "$*"
}

fail() {
  printf '%s%s%s %s\n' "$(color 31)" "FAIL" "$(color 0)" "$*"
}

port_pids() {
  local pids=""

  if command -v fuser >/dev/null 2>&1; then
    pids="$(fuser "$PROXY_PORT/tcp" 2>/dev/null || true)"
  fi

  if [[ -z "$pids" ]] && command -v ss >/dev/null 2>&1; then
    pids="$(
      ss -ltnp "sport = :$PROXY_PORT" 2>/dev/null \
        | sed -n 's/.*pid=\([0-9]\+\).*/\1/p' \
        | sort -u
    )"
  fi

  printf '%s\n' "$pids" | xargs -r -n1
}

stop_existing_proxy() {
  local pids
  pids="$(port_pids)"

  [[ -z "$pids" ]] && return 0

  printf 'Killing old proxy on %s (PID %s)...\n' "$PROXY_URL" "$(printf '%s' "$pids" | tr '\n' ' ')"
  kill $pids 2>/dev/null || true

  for _ in {1..20}; do
    [[ -z "$(port_pids)" ]] && return 0
    sleep 0.1
  done

  printf 'Old proxy did not exit cleanly; forcing it down...\n' >&2
  kill -9 $pids 2>/dev/null || true
}

read_api_key() {
  CONFIG_PATH="$CONFIG_FILE" LEGACY_SETTINGS_PATH="$CLAUDE_SETTINGS" python3 <<'PY'
import json
import os
import sys

config_path = os.environ["CONFIG_PATH"]
try:
    with open(config_path, "r", encoding="utf-8") as f:
        cfg = json.load(f)
except Exception as exc:
    cfg = {}

key = cfg.get("apiKey", "")
if not key:
    legacy_path = os.environ["LEGACY_SETTINGS_PATH"]
    try:
        with open(legacy_path, "r", encoding="utf-8") as f:
            legacy = json.load(f)
        key = legacy.get("env", {}).get("ANTHROPIC_API_KEY", "")
    except Exception:
        key = ""
if not key:
    sys.exit(2)

print(key)
PY
}

sync_claude_settings() {
  SETTINGS_PATH="$CLAUDE_SETTINGS" PROXY_URL_VALUE="$PROXY_URL" python3 <<'PY'
import json
import os

settings_path = os.environ["SETTINGS_PATH"]
proxy_url = os.environ["PROXY_URL_VALUE"]

try:
    with open(settings_path, "r", encoding="utf-8") as f:
        cfg = json.load(f)
except Exception:
    cfg = {}

env = cfg.setdefault("env", {})
env["ANTHROPIC_BASE_URL"] = proxy_url
env["ANTHROPIC_API_KEY"] = "claude-opencode-local-proxy"

os.makedirs(os.path.dirname(settings_path), exist_ok=True)
with open(settings_path, "w", encoding="utf-8") as f:
    json.dump(cfg, f, indent=2)
    f.write("\n")
PY

  chmod 600 "$CLAUDE_SETTINGS"
}

set_api_key() {
  local key="${1:-}"

  [[ -n "$key" ]] || die "Usage: claude --api <opencode-go-api-key>"

  CONFIG_PATH="$CONFIG_FILE" API_KEY="$key" DEFAULT_MODEL_VALUE="${DEFAULT_MODEL:-deepseek-v4-pro}" PROXY_HOST_VALUE="$PROXY_HOST" PROXY_PORT_VALUE="$PROXY_PORT" python3 <<'PY'
import json
import os

config_path = os.environ["CONFIG_PATH"]
api_key = os.environ["API_KEY"]

try:
    with open(config_path, "r", encoding="utf-8") as f:
        cfg = json.load(f)
except Exception:
    cfg = {}

cfg["apiKey"] = api_key
cfg.setdefault("model", os.environ["DEFAULT_MODEL_VALUE"])
cfg["proxy"] = {
    "host": os.environ["PROXY_HOST_VALUE"],
    "port": int(os.environ["PROXY_PORT_VALUE"]),
}

os.makedirs(os.path.dirname(config_path), exist_ok=True)
with open(config_path, "w", encoding="utf-8") as f:
    json.dump(cfg, f, indent=2)
    f.write("\n")
PY

  chmod 600 "$CONFIG_FILE"
  sync_claude_settings
  printf 'OpenCode Go API key stored in %s\n' "$CONFIG_FILE"
  printf 'Claude settings now point to local proxy in %s\n' "$CLAUDE_SETTINGS"
}

ensure_proxy_config() {
  CONFIG_PATH="$CONFIG_FILE" API_KEY="$API_KEY" MODEL="$DEFAULT_MODEL" PROXY_HOST_VALUE="$PROXY_HOST" PROXY_PORT_VALUE="$PROXY_PORT" python3 <<'PY'
import json
import os

config_path = os.environ["CONFIG_PATH"]

try:
    with open(config_path, "r", encoding="utf-8") as f:
        cfg = json.load(f)
except Exception:
    cfg = {}

changed = False
if not cfg.get("apiKey"):
    cfg["apiKey"] = os.environ["API_KEY"]
    changed = True
if not cfg.get("model"):
    cfg["model"] = os.environ["MODEL"]
    changed = True
if "proxy" not in cfg:
    cfg["proxy"] = {
        "host": os.environ["PROXY_HOST_VALUE"],
        "port": int(os.environ["PROXY_PORT_VALUE"]),
    }
    changed = True

if changed:
    os.makedirs(os.path.dirname(config_path), exist_ok=True)
    with open(config_path, "w", encoding="utf-8") as f:
        json.dump(cfg, f, indent=2)
        f.write("\n")
PY

  chmod 600 "$CONFIG_FILE"
}

list_go_models() {
  CONFIG_PATH="$HOME/.config/opencode/opencode.json" python3 <<'PY'
import json
import os
import re
import shutil
import subprocess
import sys

rank = [
    ("deepseek-v4-pro", "Best overall", "strong reasoning/coding"),
    ("glm-5.1", "Strong", "balanced coding"),
    ("kimi-k2.6", "Strong", "long-context coding"),
    ("minimax-m2.7", "Agent-safe", "works well with Claude tools"),
    ("qwen3.6-plus", "Strong", "fast general coding"),
    ("deepseek-v4-flash", "Fast/cheap", "huge context"),
    ("glm-5", "Good", "older GLM"),
    ("kimi-k2.5", "Good", "older Kimi"),
    ("minimax-m2.5", "Good", "older MiniMax"),
    ("qwen3.5-plus", "Good", "older Qwen"),
    ("mimo-v2.5-pro", "Specialized", "coding/general"),
    ("mimo-v2.5", "Specialized", "coding/general"),
    ("mimo-v2-pro", "Specialized", "coding/general"),
    ("mimo-v2-omni", "Specialized", "omni/general"),
]

fallback_limits = {
    "deepseek-v4-pro": (262000, 64000),
    "deepseek-v4-flash": (1000000, 384000),
    "glm-5.1": (202752, 32768),
    "glm-5": (202752, 32768),
}

def c(code):
    if os.environ.get("NO_COLOR"):
        return ""
    return f"\033[{code}m"

reset = c("0")
bold = c("1")
green = c("32")
cyan = c("36")
yellow = c("33")
magenta = c("35")
dim = c("2")

def fmt_tokens(value):
    if not value:
        return "?"
    if value >= 1_000_000:
        return f"{value / 1_000_000:.0f}M"
    if value >= 1000:
        return f"{value // 1000}k"
    return str(value)

def fmt_cost(value):
    if value is None:
        return "?"
    return f"${value:g}"

def parse_verbose_models(text):
    models = {}
    lines = text.splitlines()
    i = 0
    while i < len(lines):
        line = lines[i].strip()
        if not line.startswith("opencode-go/"):
            i += 1
            continue
        model_id = line.split("/", 1)[1]
        i += 1
        block = []
        depth = 0
        started = False
        while i < len(lines):
            cur = lines[i]
            stripped = cur.strip()
            if stripped.startswith("opencode-go/") and not started:
                break
            if "{" in cur:
                started = True
            if started:
                block.append(cur)
                depth += cur.count("{") - cur.count("}")
                if depth == 0:
                    i += 1
                    break
            i += 1
        if block:
            try:
                models[model_id] = json.loads("\n".join(block))
            except Exception:
                models[model_id] = {"id": model_id}
    return models

def load_models():
    if shutil.which("opencode"):
        try:
            out = subprocess.check_output(
                ["opencode", "models", "opencode-go", "--verbose"],
                text=True,
                stderr=subprocess.DEVNULL,
                timeout=8,
            )
            parsed = parse_verbose_models(out)
            if parsed:
                return parsed
        except Exception:
            pass

    config_path = os.environ["CONFIG_PATH"]
    try:
        with open(config_path, "r", encoding="utf-8") as f:
            cfg = json.load(f)
        return {
            model_id: {"id": model_id, **meta}
            for model_id, meta in cfg.get("provider", {}).get("opencode-go", {}).get("models", {}).items()
        }
    except Exception:
        return {}

models = load_models()
known_rank = {model: idx for idx, (model, _, _) in enumerate(rank)}
rank_meta = {model: (tier, note) for model, tier, note in rank}

ordered = sorted(
    models,
    key=lambda model: (known_rank.get(model, 999), model),
)

headers = ("#", "Model", "Tier", "Context", "Output", "In/MTok", "Out/MTok", "Notes")
rows = []
for idx, model_id in enumerate(ordered, 1):
    meta = models.get(model_id, {})
    limit = meta.get("limit", {}) or {}
    cost = meta.get("cost", {}) or {}
    context, output = fallback_limits.get(model_id, (limit.get("context"), limit.get("output")))
    tier, note = rank_meta.get(model_id, ("Available", "OpenCode Go"))
    rows.append((
        str(idx),
        f"opencode-go/{model_id}",
        tier,
        fmt_tokens(context),
        fmt_tokens(output),
        fmt_cost(cost.get("input")),
        fmt_cost(cost.get("output")),
        note,
    ))

if not rows:
    print("No OpenCode Go models found.", file=sys.stderr)
    sys.exit(1)

widths = [len(h) for h in headers]
for row in rows:
    widths = [max(widths[i], len(row[i])) for i in range(len(headers))]

def line(parts):
    return "  ".join(parts[i].ljust(widths[i]) for i in range(len(parts)))

print(f"{bold}OpenCode Go models ranked best to fallback{reset}")
print(f"{dim}Use: claude --model <model>   Example: claude --model deepseek-v4-pro{reset}\n")
print(bold + line(headers) + reset)
print(dim + line(tuple("-" * w for w in widths)) + reset)
for row in rows:
    color = green if row[0] == "1" else cyan if int(row[0]) <= 5 else yellow if "flash" in row[1] else magenta if int(row[0]) <= 10 else dim
    print(color + line(row) + reset)
PY
}

normalize_go_model() {
  local model="$1"
  model="${model#opencode-go/}"
  printf '%s\n' "$model"
}

list_go_model_ids() {
  if command -v opencode >/dev/null 2>&1; then
    opencode models opencode-go 2>/dev/null | sed 's#^opencode-go/##'
    return 0
  fi

  CONFIG_PATH="$HOME/.config/opencode/opencode.json" python3 <<'PY'
import json
import os
import sys

config_path = os.environ["CONFIG_PATH"]
try:
    with open(config_path, "r", encoding="utf-8") as f:
        cfg = json.load(f)
except Exception as exc:
    print(f"Could not read {config_path}: {exc}", file=sys.stderr)
    sys.exit(1)

for model in sorted(cfg.get("provider", {}).get("opencode-go", {}).get("models", {})):
    print(model)
PY
}

model_exists() {
  local wanted
  wanted="$(normalize_go_model "$1")"
  list_go_model_ids | grep -Fxq -- "$wanted"
}

read_default_model() {
  CONFIG_PATH="$CONFIG_FILE" LEGACY_SETTINGS_PATH="$CLAUDE_SETTINGS" python3 <<'PY'
import json
import os

try:
    with open(os.environ["CONFIG_PATH"], "r", encoding="utf-8") as f:
        cfg = json.load(f)
except Exception:
    cfg = {}

model = cfg.get("model")
if not model:
    try:
        with open(os.environ["LEGACY_SETTINGS_PATH"], "r", encoding="utf-8") as f:
            legacy = json.load(f)
        model = legacy.get("model")
    except Exception:
        model = None

print(model or "deepseek-v4-pro")
PY
}

set_default_model() {
  local model
  model="$(normalize_go_model "$1")"

  if ! model_exists "$model"; then
    printf 'Unknown OpenCode Go model: %s\n\n' "$1" >&2
    printf 'Available OpenCode Go models:\n' >&2
    list_go_models >&2
    return 1
  fi

  CONFIG_PATH="$CONFIG_FILE" MODEL="$model" PROXY_HOST_VALUE="$PROXY_HOST" PROXY_PORT_VALUE="$PROXY_PORT" python3 <<'PY'
import json
import os

config_path = os.environ["CONFIG_PATH"]
model = os.environ["MODEL"]

try:
    with open(config_path, "r", encoding="utf-8") as f:
        cfg = json.load(f)
except Exception:
    cfg = {}

cfg["model"] = model
cfg.setdefault("proxy", {
    "host": os.environ["PROXY_HOST_VALUE"],
    "port": int(os.environ["PROXY_PORT_VALUE"]),
})

os.makedirs(os.path.dirname(config_path), exist_ok=True)
with open(config_path, "w", encoding="utf-8") as f:
    json.dump(cfg, f, indent=2)
    f.write("\n")
PY

  chmod 600 "$CONFIG_FILE"
  sync_claude_settings
  printf 'Default OpenCode Go model set to: opencode-go/%s\n' "$model"
}

load_runtime_config() {
  API_KEY="$(read_api_key)" || die "Could not read API key from $CONFIG_FILE. Run: claude --api <opencode-go-api-key>"
  [[ -n "$API_KEY" ]] || die "API key is empty in $CONFIG_FILE. Run: claude --api <opencode-go-api-key>"
  DEFAULT_MODEL="$(normalize_go_model "$(read_default_model)")"
  ensure_proxy_config
  sync_claude_settings
}

print_status() {
  local health="down"
  local pids=""

  pids="$(port_pids | tr '\n' ' ')"
  if curl -fsS "$PROXY_URL/health" >/dev/null 2>&1; then
    health="ready"
  fi

  DEFAULT_MODEL="$(normalize_go_model "$(read_default_model)")"
  print_startup_table "$health"
  printf '  %-12s %s\n' "Claude bin" "$REAL_CLAUDE"
  printf '  %-12s %s\n' "Port PIDs" "${pids:-none}"
}

show_logs() {
  local mode="${1:-}"

  mkdir -p "$(dirname "$LOG_FILE")"
  touch "$LOG_FILE"

  if [[ "$mode" == "--follow" || "$mode" == "-f" ]]; then
    tail -f "$LOG_FILE"
  else
    tail -n "${CLAUDE_OPENCODE_LOG_LINES:-80}" "$LOG_FILE"
  fi
}

run_doctor() {
  local failed=0

  printf 'Claude OpenCode doctor v%s\n\n' "$(version)"

  for cmd in node npm python3 curl tar; do
    if command -v "$cmd" >/dev/null 2>&1; then
      ok "$cmd found: $(command -v "$cmd")"
    else
      fail "$cmd missing"
      failed=1
    fi
  done

  if [[ -x "$REAL_CLAUDE" ]]; then
    ok "Claude Code binary found"
  else
    fail "Claude Code binary missing: $REAL_CLAUDE"
    failed=1
  fi

  if [[ -r "$CONFIG_FILE" ]]; then
    ok "Proxy config readable: $CONFIG_FILE"
  else
    fail "Proxy config missing. Run: claude --api <opencode-go-api-key>"
    failed=1
  fi

  if API_KEY="$(read_api_key)" && [[ -n "$API_KEY" ]]; then
    ok "OpenCode Go API key configured"
  else
    fail "OpenCode Go API key missing. Run: claude --api <opencode-go-api-key>"
    failed=1
  fi

  DEFAULT_MODEL="$(normalize_go_model "$(read_default_model)")"
  if model_exists "$DEFAULT_MODEL"; then
    ok "Default model exists: opencode-go/$DEFAULT_MODEL"
  else
    warn "Default model not found in local model list: opencode-go/$DEFAULT_MODEL"
  fi

  if curl -fsS "$PROXY_URL/health" >/dev/null 2>&1; then
    ok "Proxy already reachable: $PROXY_URL"
  else
    warn "Proxy not currently running; normal claude launches start it automatically"
  fi

  if [[ "$failed" -eq 0 ]]; then
    printf '\nDoctor result: ready\n'
  else
    printf '\nDoctor result: action needed\n'
  fi

  return "$failed"
}

run_setup() {
  local key=""
  local model=""

  printf 'Claude OpenCode setup v%s\n\n' "$(version)"
  printf 'OpenCode Go API key: '
  read -r key
  set_api_key "$key"

  printf '\n'
  list_go_models || true
  printf '\nDefault model [deepseek-v4-pro]: '
  read -r model
  model="${model:-deepseek-v4-pro}"
  set_default_model "$model"

  printf '\n'
  run_doctor
}

run_update() {
  local install_dir
  install_dir="$(cd -- "$SCRIPT_DIR/.." && pwd)"

  need_cmd curl
  need_cmd tar

  printf 'Updating Claude OpenCode Proxy Service in %s\n' "$install_dir"
  CLAUDE_OPENCODE_HOME="$install_dir" \
    bash -c 'curl -fsSL https://raw.githubusercontent.com/wmostert76/claude-opencode-proxy-service/main/scripts/bootstrap.sh | bash'
}

test_one_model() {
  local model="$1"
  local start_ms end_ms latency result status

  start_ms="$(date +%s%3N)"
  result="$(
    curl -fsS -m "${CLAUDE_OPENCODE_TEST_TIMEOUT:-45}" \
      -H 'Content-Type: application/json' \
      -H 'x-api-key: claude-opencode-local-proxy' \
      -d "{\"model\":\"$model\",\"max_tokens\":32,\"messages\":[{\"role\":\"user\",\"content\":\"Reply exactly: pong\"}]}" \
      "$PROXY_URL/v1/messages" 2>&1
  )"
  status=$?
  end_ms="$(date +%s%3N)"
  latency=$((end_ms - start_ms))

  if [[ "$status" -eq 0 ]] && printf '%s' "$result" | grep -qi 'pong'; then
    printf 'OK    %-28s %6sms  pong\n' "opencode-go/$model" "$latency"
    return 0
  fi

  printf 'FAIL  %-28s %6sms  %s\n' "opencode-go/$model" "$latency" "$(printf '%s' "$result" | tr '\n' ' ' | cut -c1-120)"
  return 64
}

test_models() {
  local failed=0
  local count=0
  local model

  load_runtime_config
  stop_existing_proxy
  trap cleanup EXIT INT TERM
  CLAUDE_OPENCODE_QUIET=1 start_proxy

  printf 'Testing OpenCode Go models through %s\n\n' "$PROXY_URL"
  while IFS= read -r model; do
    [[ -z "$model" ]] && continue
    count=$((count + 1))
    if ! test_one_model "$model"; then
      failed=$((failed + 1))
    fi
  done < <(list_go_model_ids)

  printf '\nResult: %s tested, %s failed\n' "$count" "$failed"
  return "$failed"
}

maybe_handle_model_command() {
  if [[ "$#" -ge 1 ]]; then
    case "${1:-}" in
      setup)
        run_setup
        return 0
        ;;
      doctor)
        run_doctor
        return 0
        ;;
      status)
        print_status
        return 0
        ;;
      logs)
        show_logs "${2:-}"
        return 0
        ;;
      update)
        run_update
        return 0
        ;;
      models)
        if [[ "${2:-}" == "--test" ]]; then
          test_models
          return $?
        fi
        list_go_models
        return 0
        ;;
    esac
  fi

  if [[ "$#" -eq 2 && "${1:-}" == "--api" ]]; then
    set_api_key "$2"
    return 0
  fi

  if [[ "$#" -eq 1 && "${1:-}" == "--api" ]]; then
    die "Usage: claude --api <opencode-go-api-key>"
  fi

  if [[ "$#" -eq 1 && "${1:-}" == "--complete-models" ]]; then
    list_go_model_ids
    return 0
  fi

  if [[ "$#" -eq 2 && "${1:-}" == "--completion" ]]; then
    case "${2:-}" in
      fish)
        cat <<'FISH'
function __claude_opencode_go_models
    command claude --complete-models 2>/dev/null
end

complete -c claude -l model -x -a '(__claude_opencode_go_models)' -d 'Set default OpenCode Go model'
complete -c claude -s m -x -a '(__claude_opencode_go_models)' -d 'Set default OpenCode Go model'
complete -c claude -f -a 'setup doctor status logs update models' -d 'Claude OpenCode command'
FISH
        ;;
      bash)
        cat <<'BASH'
_claude_opencode_completion() {
  local cur prev
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  if [[ "$prev" == "--model" || "$prev" == "-m" ]]; then
    mapfile -t COMPREPLY < <(compgen -W "$(command claude --complete-models 2>/dev/null)" -- "$cur")
    return 0
  fi

  if [[ "$cur" == --* ]]; then
    COMPREPLY=( $(compgen -W "--api --model --help --version setup doctor status logs update models" -- "$cur") )
  fi
}

complete -F _claude_opencode_completion claude
BASH
        ;;
      *)
        die "Unsupported completion shell: $2"
        ;;
    esac
    return 0
  fi

  if [[ "$#" -eq 1 && ( "${1:-}" == "--model" || "${1:-}" == "-m" ) ]]; then
    list_go_models
    return 0
  fi

  if [[ "$#" -eq 2 && ( "${1:-}" == "--model" || "${1:-}" == "-m" ) ]]; then
    set_default_model "$2"
    return 0
  fi

  return 1
}

start_proxy() {
  mkdir -p "$(dirname "$LOG_FILE")"

  if [[ "${CLAUDE_OPENCODE_DEBUG:-0}" == "1" ]]; then
    env \
      ANTHROPIC_API_KEY="$API_KEY" \
      OPENCODE_GO_MODEL="$DEFAULT_MODEL" \
      PROXY_PORT="$PROXY_PORT" \
      node "$PROXY_SCRIPT" &
  else
    env \
      ANTHROPIC_API_KEY="$API_KEY" \
      OPENCODE_GO_MODEL="$DEFAULT_MODEL" \
      PROXY_PORT="$PROXY_PORT" \
      node "$PROXY_SCRIPT" >>"$LOG_FILE" 2>&1 &
  fi

  PROXY_PID="$!"

  for _ in {1..30}; do
    if curl -fsS "$PROXY_URL/health" >/dev/null 2>&1; then
      print_startup_table "ready"
      return 0
    fi

    if ! kill -0 "$PROXY_PID" 2>/dev/null; then
      wait "$PROXY_PID" 2>/dev/null || true
      die "Proxy exited before becoming ready"
    fi

    sleep 0.2
  done

  die "Proxy did not become ready at $PROXY_URL"
}

print_startup_table() {
  local state="$1"

  [[ "${CLAUDE_OPENCODE_QUIET:-0}" == "1" ]] && return 0
  [[ "${NO_COLOR:-}" ]] && local b="" d="" g="" c="" r="" || {
    local b=$'\033[1m'
    local d=$'\033[2m'
    local g=$'\033[32m'
    local c=$'\033[36m'
    local r=$'\033[0m'
  }

  printf '%s\n' "${b}Claude OpenCode Proxy Service${r}"
  printf '%s\n' "${d}─────────────────────────────${r}"
  printf '  %-10s %s\n' "Release" "v$(version)"
  printf '  %-10s %s\n' "State" "${g}${state}${r}"
  printf '  %-10s %s\n' "Proxy" "${c}${PROXY_URL}${r}"
  printf '  %-10s %s\n' "Provider" "OpenCode Go"
  printf '  %-10s %s\n' "Model" "opencode-go/${DEFAULT_MODEL}"
  printf '  %-10s %s\n' "Tools" "proxy web_fetch"
  printf '  %-10s %s\n' "Config" "$CONFIG_FILE"
  printf '  %-10s %s\n' "Log" "$LOG_FILE"
  printf '  %-10s %s\n' "Mode" "Claude Code passthrough + local adapter"
  printf '%s\n\n' "${d}─────────────────────────────${r}"
}

cleanup() {
  local status=$?

  if [[ -n "$PROXY_PID" ]] && kill -0 "$PROXY_PID" 2>/dev/null; then
    kill "$PROXY_PID" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
  fi

  exit "$status"
}

main() {
  local command_status

  set +e
  maybe_handle_model_command "$@"
  command_status=$?
  set -e
  if [[ "$command_status" -ne 64 ]]; then
    return "$command_status"
  fi

  need_cmd node
  need_cmd python3
  need_cmd curl

  [[ -f "$PROXY_SCRIPT" ]] || die "Proxy script not found: $PROXY_SCRIPT"
  [[ -x "$REAL_CLAUDE" ]] || die "Claude binary not found or not executable: $REAL_CLAUDE"

  load_runtime_config

  stop_existing_proxy
  trap cleanup EXIT INT TERM
  start_proxy

  ANTHROPIC_BASE_URL="$PROXY_URL" \
    ANTHROPIC_API_KEY="claude-opencode-local-proxy" \
    "$REAL_CLAUDE" --allow-dangerously-skip-permissions "$@"
}

main "$@"
